# ============================================================
# Cadeia de Custódia — Variáveis de Ambiente
# ============================================================

# --- Banco de dados ---
POSTGRES_USER=cadeia
POSTGRES_PASSWORD=cadeia_secret
POSTGRES_DB=cadeia_custodia
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://cadeia:cadeia_secret@db:5432/cadeia_custodia
DATABASE_URL_SYNC=postgresql+psycopg2://cadeia:cadeia_secret@db:5432/cadeia_custodia

# --- JWT ---
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SEGURA_DE_64_CHARS_MINIMO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- MinIO / S3 ---
MINIO_ENDPOINT=minio:9000             # Endereço interno (backend → MinIO dentro do Docker)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_PHOTOS=photos
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_TEMPLATES=templates
MINIO_BUCKET_TARGET_PHOTOS=target-photos
MINIO_USE_SSL=false
# Endereço público (browser → MinIO). Em dev: http://localhost:5173/storage (proxy Nginx).
# Em produção: https://seu-dominio.com/storage ou URL do CDN.
MINIO_PUBLIC_ENDPOINT=http://localhost:5173/storage

# --- App ---
APP_ENV=development
APP_NAME=Cadeia de Custódia
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Admin Seed ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@pericia.gov.br
ADMIN_PASSWORD=Admin@123!
ADMIN_FULL_NAME=Administrador do Sistema
